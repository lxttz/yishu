<%- partial('_partial/head') %>

<div class="container">
  <div class="tag">
    <h1 class="tag-title"><%= __('tag') %>: <%= page.tag %></h1>
    <div class="tag-posts">
      <% page.posts.each(function(post) { %>
      <article class="tag-post">
        <div class="tag-post-header">
          <h2 class="tag-post-title">
            <a href="/<%= post.path %>" class="tag-post-title-link"><%= post.title %></a>
          </h2>
          <div class="tag-post-meta">
            <span class="tag-post-date"><%= post.date.format('YYYY-MM-DD') %></span>
          </div>
        </div>
      </article>
      <% }); %>
    </div>

    <% if (page.total > 1) { %>
    <nav class="pagination">
      <% if (page.prev) { %>
      <a href="/<%= page.prev %>"><%= theme.pagination.prev_text %></a>
      <% } %>
      <% if (page.next) { %>
      <a href="/<%= page.next %>"><%= theme.pagination.next_text %></a>
      <% } %>
    </nav>
    <% } %>
  </div>
</div>

<%- partial('_partial/footer') %>