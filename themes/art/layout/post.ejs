<%- partial('_partial/head') %>

<%- partial('featured') %>

<div class="container">
  <article class="post-detail">
    <!-- Main Content -->
    <div class="post-content">
      <%- page.content %>
    </div>
    
    <!-- Tags -->
    <% if (page.tags && page.tags.length) { %>
    <div class="post-tags">
      <% page.tags.each(function(tag) { %>
      <a href="/<%= tag.path %>" class="post-tag"><%= tag.name %></a>
      <% }); %>
    </div>
    <% } %>
    
    <!-- Comments -->
    <% if (theme.comment.enable) { %>
    <div class="post-comment">
      <!-- Comment System -->
    </div>
    <% } %>
  </article>
</div>

<style>
  /* Post Detail Styles */
  .post-detail {
    color: #333;
    background-color: #fff;
  }
  
  /* Featured Section */
  .featured-section {
    width: 100%;
    margin-top: 0;
  }
  
  .featured-image {
    position: relative;
    width: 100%;
    height: 50vh;
    min-height: 350px;
    overflow: hidden;
  }
  
  .featured-image::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: var(--bg-image);
    background-size: cover;
    background-position: center;
    opacity: 0.9;
    z-index: 1;
  }
  
  .featured-content {
    position: relative;
    z-index: 2;
    padding: 40px;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
  }
  
  .featured-category {
    margin-bottom: 20px;
  }
  
  .featured-category-link {
    display: inline-block;
    padding: 4px 12px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 2px;
    font-size: 14px;
    color: #000;
    text-decoration: none;
    margin-right: 8px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 500;
    transition: all 0.3s ease;
  }
  
  .featured-category-link:hover {
    background-color: rgba(0, 0, 0, 0.9);
    color: #fff;
  }
  
  .featured-title {
    font-size: 42px;
    font-weight: normal;
    margin-bottom: 15px;
    line-height: 1.2;
    color: #fff;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
  }
  
  .featured-meta {
    font-size: 16px;
    margin-bottom: 15px;
    display: flex;
    gap: 20px;
    color: rgba(255, 255, 255, 0.8);
  }
  
  .featured-date,
  .featured-updated {
    display: flex;
    align-items: center;
  }
  
  .featured-description {
    font-size: 18px;
    line-height: 1.5;
    max-width: 600px;
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
  }
  
  /* Main Content */
  .post-content {
    max-width: 800px;
    margin: 60px auto;
    padding: 0 40px;
    line-height: 1.7;
    font-size: 15px;
    color: #333;
  }
  
  .post-content h1,
  .post-content h2,
  .post-content h3,
  .post-content h4,
  .post-content h5,
  .post-content h6 {
    margin-top: 40px;
    margin-bottom: 20px;
    font-weight: normal;
    color: #000;
    font-size: 20px;
  }
  
  .post-content p {
    margin-bottom: 25px;
    text-align: left;
  }
  
  .post-content img {
    max-width: 100%;
    height: auto;
    margin: 30px 0;
  }
  
  .post-content a {
    color: #000;
    text-decoration: underline;
    transition: color 0.3s ease;
  }
  
  .post-content a:hover {
    color: #666;
  }
  
  /* Tags */
  .post-tags {
    max-width: 800px;
    margin: 0 auto 60px;
    padding: 0 40px;
    padding-top: 30px;
    border-top: 1px solid #e0e0e0;
  }
  
  .post-tag {
    display: inline-block;
    padding: 4px 12px;
    background-color: #f0f0f0;
    border-radius: 2px;
    font-size: 12px;
    color: #666;
    text-decoration: none;
    margin-right: 10px;
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.3s ease;
  }
  
  .post-tag:hover {
    background-color: #000;
    color: #fff;
  }
  
  /* Responsive Styles */
  @media (max-width: 768px) {
    .featured-image {
      height: 50vh;
      min-height: 350px;
    }
    
    .featured-content {
      padding: 30px;
    }
    
    .featured-title {
      font-size: 28px;
    }
    
    .featured-meta {
      flex-direction: column;
      gap: 5px;
    }
    
    .post-content {
      margin: 40px auto;
      padding: 0 20px;
      font-size: 14px;
      line-height: 1.6;
    }
    
    .post-tags {
      margin-bottom: 40px;
      padding: 0 20px;
    }
  }
  
  @media (max-width: 480px) {
    .post-hero-title {
      font-size: 24px;
    }
    
    .post-hero-description {
      font-size: 13px;
    }
  }
</style>

<%- partial('_partial/footer') %>