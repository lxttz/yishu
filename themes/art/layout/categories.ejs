<%- partial('_partial/head') %>

<style>
  /* Categories Page Styles */
  .categories-page {
    padding-top: 20px;
    min-height: 100vh;
    background-color: #000;
    color: #fff;
  }
  
  .categories-header {
    padding: 40px;
    text-align: center;
  }
  
  .categories-title {
    font-size: 32px;
    font-weight: bold;
    letter-spacing: 2px;
    margin-bottom: 20px;
  }
  
  .category-nav {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 40px;
  }
  
  .category-nav-item {
    padding: 8px 20px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 20px;
    transition: all 0.3s ease;
  }
  
  .category-nav-item:hover {
    border-color: #fff;
    transform: translateY(-2px);
  }
  
  .category-nav-link {
    text-decoration: none;
    color: #fff;
    font-size: 14px;
    letter-spacing: 1px;
  }
  
  .category-nav-link.active {
    color: #007bff;
    border-color: #007bff;
  }
  
  /* Posts Grid */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 60px;
    padding: 0 40px;
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .post-item {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    cursor: pointer;
    max-width: 300px;
  }
  
  .post-card {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .post-card-front {
    width: 100%;
    height: 100%;
    background-color: #000;
    transition: filter 0.4s ease;
  }

  .post-item:hover .post-card-front {
    filter: blur(8px);
  }

  .post-card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 2;
  }

  .post-item:hover .post-card-overlay {
    opacity: 1;
  }

  .post-card-back {
    display: none;
  }
  
  .post-card-content {
    text-align: center;
    width: 100%;
    position: relative;
    z-index: 2;
  }
  
  .post-img {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  
  .post-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  
  .post-card-content {
    text-align: center;
    width: 100%;
  }
  
  .post-card-title {
    font-size: 16px;
    font-weight: bold;
    margin-bottom: 10px;
    line-height: 1.3;
    color: #fff;
  }
  
  .post-card-description {
    font-size: 13px;
    line-height: 1.4;
    margin-bottom: 15px;
    color: rgba(255, 255, 255, 0.8);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
  }
  
  .post-card-date {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }
  
  /* Pagination Styles */
  .pagination {
    display: flex;
    justify-content: center;
    margin: 60px 0;
    padding: 0 40px;
  }
  
  .pagination a {
    text-decoration: none;
    color: #fff;
    padding: 10px 20px;
    margin: 0 10px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 4px;
    transition: all 0.3s ease;
  }
  
  .pagination a:hover {
    border-color: #fff;
    color: #007bff;
  }
  
  /* Responsive Styles */
  @media (max-width: 1400px) {
    .posts-grid {
      grid-template-columns: repeat(4, 1fr);
      max-width: 1200px;
      gap: 40px;
    }
    
    .post-item {
      max-width: 250px;
    }
  }
  
  @media (max-width: 1200px) {
    .posts-grid {
      grid-template-columns: repeat(3, 1fr);
      max-width: 900px;
      gap: 30px;
    }
    
    .post-item {
      max-width: 250px;
    }
  }
  
  @media (max-width: 768px) {
    .categories-header {
      padding: 20px;
    }
    
    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
      padding: 0 20px;
      max-width: 600px;
      gap: 30px;
    }
    
    .post-item {
      max-width: 250px;
    }
  }
  
  @media (max-width: 480px) {
    .posts-grid {
      grid-template-columns: 1fr;
      padding: 0 10px;
      max-width: 300px;
      gap: 20px;
    }
    
    .post-item {
      max-width: 250px;
    }
  }
</style>

<main class="categories-page">
  <div class="container">
    <div class="categories-header">
      <h1 class="categories-title">CATEGORIES</h1>
      
      <!-- Category Navigation -->
      <div class="category-nav">
        <% const categories = site.categories %>
        <% categories.each(function(category) { %>
        <div class="category-nav-item">
          <a href="/<%= category.path %>" class="category-nav-link">
            <%= category.name %>
          </a>
        </div>
        <% }); %>
      </div>
    </div>

    <!-- Posts Grid -->
    <div class="posts-grid">
      <% site.posts.each(function(post) { %>
      <a href="/<%= post.path %>" class="post-item">
        <div class="post-card">
          <div class="post-card-front">
            <div class="post-img">
              <% if (post.index_img) { %>
              <img src="<%= post.index_img %>" alt="<%= post.title %>">
              <% } else { %>
              <img src="/img/00.png" alt="<%= post.title %>">
              <% } %>
            </div>
          </div>
          <div class="post-card-overlay">
            <div class="post-card-content">
              <h3 class="post-card-title"><%= post.title %></h3>
              <% if (post.description) { %>
              <p class="post-card-description"><%= post.description %></p>
              <% } %>
              <p class="post-card-date"><%= post.date.format('YYYY-MM-DD') %></p>
            </div>
          </div>
        </div>
      </a>
      <% }); %>
    </div>

    <% if (page.total > 1) { %>
    <nav class="pagination">
      <% if (page.prev) { %>
      <a href="/<%= page.prev %>">PREV</a>
      <% } %>
      <% if (page.next) { %>
      <a href="/<%= page.next %>">NEXT</a>
      <% } %>
    </nav>
    <% } %>
  </div>
</main>

<%- partial('_partial/footer') %>