  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="copyright">
          <%= theme.footer.copyright %>
        </div>
        <div class="powered">
          <%= theme.footer.powered %>
        </div>
        <% if (theme.social) { %>
        <div class="social">
          <% for (let item in theme.social) { %>
          <a href="<%= theme.social[item] %>" class="social-link" target="_blank"><%= item %></a>
          <% } %>
        </div>
        <% } %>
      </div>
    </div>
  </footer>

  <script src="<%= theme.js || '/js/main.js' %>"></script>
  <% if (theme.analytics.enable) { %>
  <!-- Analytics Code -->
  <% } %>
</body>
</html>